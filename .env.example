# Supabase Connection
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service Role (Server Side Only - REQUIRED FOR ADMIN ACTIONS)
# DO NOT PREFIX WITH NEXT_PUBLIC_
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Administrative Configuration
# Change this to something secret like '/portal-9921' to hide the admin dashboard
NEXT_PUBLIC_ADMIN_PATH=/ctrl-sm-2026

# Tawk.to Chat (Optional)
NEXT_PUBLIC_TAWK_PROPERTY_ID=
NEXT_PUBLIC_TAWK_WIDGET_ID=
